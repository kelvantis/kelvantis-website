{
  "buildCommand": "node build.mjs",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/pakketten/:path*", "destination": "/contact", "permanent": true },
    { "source": "/diensten/seo", "destination": "/geo-aeo", "permanent": true },
    { "source": "/diensten/seo.html", "destination": "/geo-aeo", "permanent": true },
    { "source": "/diensten/geo-aeo", "destination": "/geo-aeo", "permanent": true },
    { "source": "/diensten/geo-aeo.html", "destination": "/geo-aeo", "permanent": true },
    { "source": "/diensten/ai-implementatie", "destination": "/ai-implementatie", "permanent": true },
    { "source": "/diensten/ai-implementatie.html", "destination": "/ai-implementatie", "permanent": true },
    { "source": "/diensten/workflow-automatisering", "destination": "/workflow-automatisering", "permanent": true },
    { "source": "/diensten/workflow-automatisering.html", "destination": "/workflow-automatisering", "permanent": true },
    { "source": "/diensten/website-laten-maken", "destination": "/website-laten-maken", "permanent": true },
    { "source": "/diensten/website-laten-maken.html", "destination": "/website-laten-maken", "permanent": true },
    { "source": "/diensten/:path*", "destination": "/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://www.googletagmanager.com https://www.google-analytics.com; connect-src 'self' https://formspree.io https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com; form-action 'self' https://formspree.io; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; upgrade-insecure-requests"
        }
      ]
    }
  ]
}
